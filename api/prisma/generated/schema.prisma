// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

// ─── Entités principales ──────────────────────────────────

model Role {
  id     Int    @id @default(autoincrement())
  frName String
  name   String
  users  User[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("roles")
}

model User {
  id             Int     @id @default(autoincrement())
  email          String  @unique
  firstname      String?
  lastname       String?
  password       String
  pseudo         String  @unique
  urlProfilImage String? @map("url_profil_image")

  verified    Boolean @default(false)
  verifyToken String? @map("verify_token")

  resetToken       String?   @map("reset_token")
  resetTokenExpiry DateTime? @map("reset_token_expiry")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  role          Role           @relation(fields: [roleId], references: [id])
  roleId        Int            @default(0) @map("role_id")
  createdCours  Cours[]        @relation("CreatedCours")
  badges        UserHasBadge[]
  enrollments   UserHasCours[]
  activations   CoursStarted[]
  commentaires  Comment[]
  opinions      Opinion[]
  notifications Notification[]
  refreshTokens RefreshToken[]

  @@map("users")
}

model Cours {
  id            Int     @id @default(autoincrement())
  title         String  @unique
  slug          String  @unique
  littleSummary String? @map("little_summary")
  urlImage      String? @map("url_image")
  difficulty    Int
  summary       String?
  visibility    Boolean @default(false)
  numberPage    Int     @map("number_page")

  note Int @default(0)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  author             User                        @relation("CreatedCours", fields: [authorId], references: [id], onDelete: Restrict)
  authorId           Int                         @map("author_id")
  category           Category                    @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  categoryId         Int                         @map("category_id")
  tools              CoursHasTool[]
  learningObjectives CoursHasLearningObjective[]
  content            CoursContent[]
  enrollments        UserHasCours[]
  activations        CoursStarted[]
  comments           Comment[]
  opinions           Opinion[]
  notifications      Notification[]

  @@map("courses")
}

model CoursContent {
  id         Int    @id @default(autoincrement())
  coursId    Int    @map("cours_id")
  numberPage Int    @map("number_page")
  content    String

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  cours Cours @relation(fields: [coursId], references: [id], onDelete: Cascade)

  @@map("cours_content")
}

model Category {
  id              Int     @id @default(autoincrement())
  name            String
  description     String?
  textColor       String  @map("text_color")
  borderColor     String  @map("border_color")
  backgroundColor String  @map("background_color")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  courses Cours[]

  @@map("categories")
}

model LearningObjective {
  id          Int     @id @default(autoincrement())
  title       String
  description String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  courses CoursHasLearningObjective[]

  @@map("learning_objectives")
}

model Tool {
  id          Int     @id @default(autoincrement())
  name        String
  description String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  cours CoursHasTool[]

  @@map("tools")
}

model Badge {
  id          Int     @id @default(autoincrement())
  name        String
  description String?
  icon        String
  color       String

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users UserHasBadge[]

  @@map("badge")
}

// ─── Tables de liaison ────────────────────────────────────

model UserHasCours {
  id      Int @id @default(autoincrement())
  userId  Int @map("user_id")
  coursId Int @map("cours_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  cours Cours @relation(fields: [coursId], references: [id], onDelete: Cascade)

  @@unique([userId, coursId])
  @@map("user_has_cours")
}

model CoursStarted {
  id      Int     @id @default(autoincrement())
  userId  Int     @map("user_id")
  coursId Int     @map("cours_id")
  IsEnd   Boolean @default(false) @map("is_end")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  cours Cours @relation(fields: [coursId], references: [id], onDelete: Cascade)

  @@unique([userId, coursId])
  @@map("cours_started")
}

model UserHasBadge {
  id      Int @id @default(autoincrement())
  userId  Int @map("user_id")
  badgeId Int @map("badge_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@map("user_has_bagde")
}

model CoursHasTool {
  id      Int @id @default(autoincrement())
  coursId Int @map("cours_id")
  toolsId Int @map("tools_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  cours Cours @relation(fields: [coursId], references: [id], onDelete: Cascade)
  tools Tool  @relation(fields: [toolsId], references: [id], onDelete: Cascade)

  @@unique([coursId, toolsId])
  @@map("cours_has_tool")
}

model CoursHasLearningObjective {
  id                  Int @id @default(autoincrement())
  coursId             Int @map("cours_id")
  learningObjectiveId Int @map("lerning_objective")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  cours    Cours             @relation(fields: [coursId], references: [id], onDelete: Cascade)
  objectif LearningObjective @relation(fields: [learningObjectiveId], references: [id], onDelete: Cascade)

  @@unique([coursId, learningObjectiveId])
  @@map("cours_has_learning_objective")
}

// ─── Social ───────────────────────────────────────────────

model Comment {
  id          Int    @id @default(autoincrement())
  description String
  coursId     Int    @map("cours_id")
  authorId    Int    @map("author_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  cours  Cours @relation(fields: [coursId], references: [id], onDelete: Cascade)
  author User  @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@map("comments")
}

model Opinion {
  id      Int    @id @default(autoincrement())
  content String
  note    Int
  coursId Int    @map("cours_id")
  userId  Int    @map("user_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  cours Cours @relation(fields: [coursId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, coursId])
  @@map("opinions")
}

model Notification {
  id       Int     @id @default(autoincrement())
  content  String
  seen     Boolean @default(false)
  targetId Int     @unique @map("target_id")

  coursId Int @map("cours_id")
  userId  Int @map("user_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  cours Cours @relation(fields: [coursId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model RefreshToken {
  id    Int    @id @default(autoincrement())
  token String @unique

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId Int  @map("user_id")

  @@index([userId])
  @@map("refresh_tokens")
}
