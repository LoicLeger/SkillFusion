{
  "name": "api",
  "version": "1.0.0",
  "description": "",
  "main": "app.ts",
  "prisma": {
    "schema": "./prisma/schema.prisma"
  },
  "scripts": {
    "start": "npx prisma migrate reset --force && npx tsx src/models/seeding.ts && tsx app.ts",
    "test:unit": "tsx --test ./**/*.unit.test.ts",
    "test:spec": "tsx --test --env-file=./test/config/.env.test --import ./test/config/global-setup.ts --experimental-test-isolation=none ./**/*.spec.test.ts",
    "test": "npm run test:unit && npm run test:spec",
    "dev": "tsx --watch --env-file=.env app.ts",
    "db:deploy": "npx prisma migrate deploy",
    "db:seed": "npx tsx src/models/seeding.ts",
    "db:reset": "npx prisma migrate reset && npx prisma generate && npm run db:deploy && npm run db:seed"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "argon2": "^0.44.0",
    "axios": "^1.15.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "express-xss-sanitizer": "^2.0.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^8.0.7",
    "pg": "^8.20.0",
    "tsx": "^4.21.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-xss-sanitizer": "^2.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "@types/sanitize-html": "^2.16.1",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "eslint": "^10.2.1",
    "prettier": "^3.8.3",
    "prisma": "^7.6.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.3"
  }
}